# Elastos Node Monitor Configuration
# This file is auto-generated by install.sh — you rarely need to edit it.

# Port the dashboard runs on
PORT=9999

# Auth token (auto-generated during install)
AUTH_TOKEN=

# Path to your Elastos node directory (where node.sh lives)
ELASTOS_NODE_DIR=

# Server specs are auto-detected at startup, but you can override them here:
# CPU_CORES=16
# RAM_GB=64
# DISK_GB=600
# DISK_MOUNT=/
